{
  "name": "@memoriaali/api-types",
  "version": "2.0.0",
  "description": "API contracts and type definitions for Memoriaali project",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "pnpm --filter @memoriaali/database db:generate db:seed",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage",
    "spec": "vitest --run",
    "spec:watch": "vitest --watch",
    "spec:coverage": "vitest --run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit --project tsconfig.typecheck.json",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@memoriaali/prettier-config": "workspace:*",
    "@memoriaali/tsconfig": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "rimraf": "^6.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./generated": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
