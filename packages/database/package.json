{
  "name": "@memoriaali/database",
  "version": "1.0.0",
  "description": "Prisma database schema and migrations for Memoriaali",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./secure-client": {
      "types": "./dist/src/secure-client.d.ts",
      "import": "./dist/src/secure-client.js",
      "require": "./dist/src/secure-client.js"
    },
    "./generated/client": {
      "types": "./generated/client/index.d.ts",
      "import": "./generated/client/index.js",
      "require": "./generated/client/index.js"
    },
    "./src/*": {
      "types": "./src/*",
      "import": "./src/*",
      "require": "./src/*"
    }
  },
  "files": [
    "dist/",
    "generated/",
    "src/",
    "schema.prisma"
  ],
  "scripts": {
    "build": "tsc && cp -r generated/client dist/generated/",
    "clean": "rm -rf dist && rm -rf generated",
    "prebuild": "pnpm db:generate",
    "db:generate": "prisma generate && node scripts/fix-generated-imports.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx seeds/index.ts",
    "db:studio": "prisma studio",
    "lint": "echo 'No linting rules for database schema files'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage",
    "test:setup": "./scripts/setup-database-test-env.sh",
    "test:teardown": "./scripts/teardown-database-test-env.sh",
    "test:with-env": "./scripts/setup-database-test-env.sh && vitest --run && ./scripts/teardown-database-test-env.sh"
  },
  "dependencies": {
    "@memoriaali/api-types": "workspace:*",
    "@memoriaali/shared": "workspace:*",
    "@prisma/client": "^6.14.0",
    "@types/http-link-header": "^1.0.7",
    "http-link-header": "^1.1.3",
    "prisma-field-encryption": "^1.6.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@memoriaali/prettier-config": "workspace:*",
    "@memoriaali/tsconfig": "workspace:*",
    "@prisma/generator-helper": "^6.14.0",
    "@prisma/sdk": "^4.0.0",
    "@types/node": "^20.17.10",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "^6.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod-prisma-types": "^3.3.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
