{
  "extends": "@memoriaali/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "exactOptionalPropertyTypes": false,
    "module": "ES2022",
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    }
  },
  "include": ["src/**/*.ts", "seeds/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/__specs__/**", "**/__tests__/**"]
}
