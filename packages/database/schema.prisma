/// **REFRESH TOKEN MODEL**
/// JWT refresh token management for secure session handling
/// 
/// **Purpose**: Manages refresh tokens for secure, stateless authentication
/// **Security**: Enables token rotation and session invalidation
/// **Simplicity**: Minimal audit fields as tokens are ephemeral security tokens
/// **Performance**: Token validation and cleanup of expired tokens
model RefreshToken {
  id     String @id @default(uuid()) /// UUID primary key
  userId String @map("user_id") /// Token owner
  token  String @db.Text /// @never-expose @gdpr.category(TECHNICAL) @gdpr.purpose(AUTHENTICATION) @gdpr.retention(1_YEAR) - Hashed refresh token

  // ===== SIMPLE AUDIT FIELDS =====
  // Note: Tokens don't need full audit trails as they're ephemeral security tokens
  createdAt DateTime @default(now()) @map("created_at") /// Token generation time
  updatedAt DateTime @updatedAt @map("updated_at") /// Last token use/refresh

  // ===== RELATIONSHIPS =====
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ===== PERFORMANCE INDEXES =====
  @@index([userId])
  @@index([token(length: 100)])
  @@map("refresh_tokens")
}

// ================================================================================================
// ENUMS - Type-safe constants for workflow states and classifications
// ================================================================================================

/// **USER ROLE ENUM**
/// Hierarchical permission system for the archival platform
/// 
/// **Hierarchy**: ADMIN > MODERATOR > EXPERT > USER
/// - ADMIN: Full system administration, configuration, user management
/// - MODERATOR: Content moderation, approval workflows, institutional oversight
/// - EXPERT: Enhanced metadata editing, specialized archival functions, quality control
/// - USER: Basic document upload, viewing, commenting, research requests
enum UserRole {
  ADMIN /// System administrators with full access
  MODERATOR /// Content moderators and institutional managers
  USER /// Basic users with upload and viewing permissions
  EXPERT /// Power users with enhanced metadata editing capabilities
}

/// **ACCOUNT TYPE ENUM**
/// Determines available user profile fields and institutional classification
/// 
/// - PRIVATE: Individual users (researchers, students, general public)
/// - COMPANY: Organizational users requiring business contact information
enum AccountType {
  PRIVATE /// Individual user account
  COMPANY /// Organizational account with business fields
}

/// **DOCUMENT PRIVACY ENUM**
/// Access control levels for documents in the archival system
/// 
/// **Access Levels**:
/// - PUBLIC: Openly accessible to all authenticated users
/// - PRIVATE: Only accessible to document owner
/// - GROUP: Shared with specific group members only
/// - RESEARCH_ONLY: Requires approved research request for access
enum DocPrivacy {
  PUBLIC /// Publicly accessible to all users
  PRIVATE /// Only accessible to document owner
  GROUP /// Shared with specific group members
  RESEARCH_ONLY /// Requires research request approval
}

/// **COMMENT STATE ENUM**
/// Moderation workflow states for user comments
/// 
/// **Workflow**: PENDING → APPROVED/REJECTED
/// - PENDING: Awaiting moderator review
/// - APPROVED: Approved for public display
/// - REJECTED: Rejected and hidden from public view
enum CommentState {
  PENDING /// Awaiting moderation review
  APPROVED /// Approved for public display
  REJECTED /// Rejected and hidden
}

/// **SUGGESTION STATE ENUM**
/// Approval workflow for metadata improvement suggestions
/// 
/// **Workflow**: PENDING → APPROVED/REJECTED
/// - PENDING: Awaiting expert or moderator review
/// - APPROVED: Accepted and applied to document metadata
/// - REJECTED: Declined with optional explanation
enum SuggestionState {
  PENDING /// Awaiting expert review
  APPROVED /// Accepted and applied
  VERIFIED /// Verified by expert
  REJECTED /// Declined
}

/// **REQUEST STATE ENUM**
/// Approval workflow for research access requests
/// 
/// **Workflow**: PENDING → APPROVED/REJECTED
/// - PENDING: Awaiting institutional approval
/// - APPROVED: Access granted to restricted document
/// - REJECTED: Access denied with optional explanation
enum RequestState {
  PENDING /// Awaiting institutional approval
  APPROVED /// Access granted
  REJECTED /// Access denied
}

/// **IRI TYPE ENUM**
/// Categories of linked data entities for semantic web integration
/// 
/// **Entity Types**:
/// - PERSON: Individual people (authors, subjects, interviewees)
/// - PLACE: Geographic locations (cities, buildings, regions)
/// - EVENT: Historical events (wars, celebrations, milestones)
/// - CONCEPT: Abstract concepts (themes, topics, subjects)
/// - ORGANIZATION: Institutions, companies, groups
enum IriType {
  PERSON /// Individual people and persons
  PLACE /// Geographic locations and places
  EVENT /// Historical events and occurrences
  CONCEPT /// Abstract concepts and themes
  ORGANIZATION /// Institutions and organizations
}

/// **DOCUMENT ERROR TYPE ENUM**
/// Quality issues detected in scanned documents (Finnish archival compliance)
/// 
/// **Error Categories**:
/// - POST_IT: Post-it notes detected in scan (should be removed)
/// - FOLDED_CORNER: Page corner folded during scanning
/// - EMPTY_PAGE: Blank or nearly blank page detected
/// - BLURRED_TEXT: Text quality issues affecting OCR accuracy
/// - POOR_QUALITY: General image quality problems
/// - DAMAGED_ORIGINAL: Physical damage to original document visible in scan
enum DocumentErrorType {
  POST_IT /// Post-it notes detected on document
  FOLDED_CORNER /// Page corner folded during scanning
  EMPTY_PAGE /// Blank or nearly empty page
  BLURRED_TEXT /// Text quality affects OCR
  POOR_QUALITY /// General image quality issues
  DAMAGED_ORIGINAL /// Physical damage to original document
}
