{
  "name": "@memoriaali/shared",
  "version": "1.0.0",
  "description": "Shared utilities and types for Memoriaali project",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage",
    "spec": "vitest --run",
    "spec:watch": "vitest --watch",
    "spec:coverage": "vitest --run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@memoriaali/prettier-config": "workspace:*",
    "@memoriaali/tsconfig": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.17.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "rimraf": "^6.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
