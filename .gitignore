# Monorepo gitignore for Memoriaali v2.0

# Dependencies
node_modules/
.pnp
.pnp.js

# Production builds
dist/
build/
target/
.next/
out/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Turborepo
.turbo

# Database
*.db
*.db-journal

# Prisma
/packages/database/prisma/migrations/dev.db*

# Generated code - should be generated on build
packages/database/generated/
packages/api-types/src/generated/

# Java
*.class
*.jar
*.war
*.ear
hs_err_pid*

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Docker
.dockerignore

# SIP packages and uploads
/apps/backend/storage/
/apps/sip-service/output/
*.sip
*.zip

# Legacy system specific ignores (preserved from v1.x)
/legacy/back/media/
/legacy/back/certs/db.json
/legacy/back/certs/email.json
/legacy/back/certs/ftps.json
/legacy/back/node_modules/
/legacy/front/node_modules/

# Certificate files
*.key
*.crt
*.pem
*.p12

# Configuration files with sensitive data
config/local.json
config/production.json

# Test artifacts
/test-results/
/playwright-report/
/playwright/.cache/


site
mkdocs.yml
scripts/

# Local temporary planning, testing and reporting related files
_process/

logs
