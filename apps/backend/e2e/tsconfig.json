{
  "extends": "../../../tools/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "@memoriaali/database": ["../../../packages/database/src"],
      "@memoriaali/database/generated/client": ["../../../packages/database/generated/client"],
      "@memoriaali/api-types": ["../../../packages/api-types/src"],
      "@memoriaali/api-types/generated": ["../../../packages/api-types/src/generated"],
      "@memoriaali/shared": ["../../../packages/shared/src"]
    },
    "types": ["node"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx", "../src/**/*.ts"],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
