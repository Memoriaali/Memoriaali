# JWT (generate a secure secret for production)
JWT_SECRET="dev-secret-key-change-in-production"

# Email verification settings
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE="false"
SMTP_USER="user"
SMTP_PASS="pass"
FROM_EMAIL="yllapito@memoriaali.fi"

# Set true, if you want test email sending with Mailpit
FORCE_EMAIL_SEND=false

# Valid @47ng/cloak key format for dev/testing (do NOT use in production)
DATABASE_ENCRYPTION_KEY="k1.aesgcm256.Np1RB2LVH1QmUi97_BPIQOMNONFvzD5qP82fXLA7yNw="

# The variant of the system. The variant will affect on the 
# localization, features and organization info in use with the system.
# Please, notice that the same variable must be set to the frontend's env 
# variable too.
MEMORIAALI_VARIANT=default

# ===== SIP Package Generation Configuration =====
# Path to the official commons-ip2 CLI JAR file
# Download from: https://github.com/keeps/commons-ip/releases/tag/2.10.0
SIP_JAR_PATH="./jars/commons-ip-cli-2.10.0.jar"

# Output directory for completed SIP packages
# Packages are stored here after creation and validation
SIP_OUTPUT_PATH="/app/storage/sips"

# Retention period for SIP packages (in days)
# After this period, packages may be archived or cleaned up
SIP_RETENTION_DAYS=30

# Optional Java configuration
# JAVA_EXECUTABLE_PATH=java
# JAVA_HEAP_INITIAL=256m
# JAVA_HEAP_MAX=1g
# JAVA_PROCESS_TIMEOUT=300000  # 5 minutes default
# JAVA_WORKING_DIR=.

# Disable rate limiting, for testing
DISABLE_RATE_LIMITING=false
# Disable origin checks, for testing
DISABLE_ORIGIN_CHECK=false

# The shared secret key between the archiver and backend intercommunication
WORKER_AUTH_SECRET="--fill-with-a-big-secret--"