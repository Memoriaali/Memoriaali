{
  "name": "@memoriaali/backend",
  "version": "1.0.0",
  "description": "Modern TypeScript backend for Memoriaali v2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run test:integration:conditional",
    "test:unit": "npx vitest run src/api/users/__specs__/users.unit.spec.ts",
    "test:unit:watch": "npx vitest watch src/api/users/__specs__/users.unit.spec.ts",
    "test:unit:coverage": "npx vitest run --coverage src/api/users/__specs__/users.unit.spec.ts",
    "test:integration": "cd e2e && npm run test:api",
    "test:integration:conditional": "bash scripts/test-integration-conditional.sh",
    "test:integration:watch": "cd e2e && npm run test:api:watch",
    "test:integration:coverage": "cd e2e && npm run test:coverage",
    "test:e2e": "npm run test:integration",
    "test:e2e:conditional": "npm run test:integration:conditional",
    "test:e2e:ui": "npm run test:integration:watch",
    "test:all": "npm run test:unit && npm run test:integration",
    "spec": "npm run test:unit",
    "spec:watch": "npm run test:unit:watch",
    "spec:coverage": "npm run test:unit:coverage",
    "lint:dev": "eslint --config eslint.config.dev.js src",
    "lint:quality": "eslint --config eslint.config.quality.js src",
    "lint:fix": "eslint --config eslint.config.dev.js src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "validate:env": "bash scripts/validate-env.sh",
    "debug:env": "bash scripts/debug-env.sh"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@memoriaali/access-control": "workspace:*",
    "@memoriaali/api-types": "workspace:*",
    "@memoriaali/database": "workspace:*",
    "@memoriaali/shared": "workspace:*",
    "@memoriaali/variant-config": "workspace:*",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "prisma-field-encryption": "^1.6.0",
    "redoc-express": "^2.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^4.1.13",
    "zod-openapi": "^5.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@memoriaali/prettier-config": "workspace:*",
    "@memoriaali/tsconfig": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "rimraf": "^6.1.2",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
