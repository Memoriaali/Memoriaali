{
  "extends": "../../tools/tsconfig/react.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "downlevelIteration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["@testing-library/jest-dom/vitest"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@memoriaali/api-types": ["../../packages/api-types/dist"],
      "@memoriaali/api-types/*": ["../../packages/api-types/dist/*"],
      "@memoriaali/shared": ["../../packages/shared/dist"],
      "@memoriaali/shared/*": ["../../packages/shared/dist/*"],
      "@seeds": ["../../packages/database/seeds"],
      "@seeds/*": ["../../packages/database/seeds/*"],
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/app/*": ["./src/app/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/types/*": ["./src/types/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "coverage",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__specs__/**",
    "src/lib/api/generated/**/*",
    "src/lib/api/generated/**/*.ts",
    "src/lib/api/generated/**/*.tsx"
  ]
}
