{
  "extends": "@memoriaali/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es6"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@utils/*": ["./tests/utils/*"],
      "@pages/*": ["./tests/pages/*"]
    },
    "types": ["@playwright/test", "node"]
  },
  "include": ["**/*.ts", "**/*.tsx", "playwright.config.ts"],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
