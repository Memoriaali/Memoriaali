{
  "name": "@memoriaali/frontend",
  "version": "1.0.0",
  "description": "Next.js frontend for Memoriaali v2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint:dev": "eslint --config eslint.config.dev.mjs src",
    "lint:quality": "eslint --config eslint.config.quality.mjs src",
    "lint:fix": "eslint --config eslint.config.dev.mjs src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "cd e2e && npm run test:ui",
    "test:e2e:conditional": "bash scripts/test-e2e-conditional.sh",
    "test:e2e:ui": "cd e2e && npm run test:ui:headed",
    "test:e2e:debug": "cd e2e && npm run test:ui:debug",
    "test:e2e:setup": "cd e2e && npm run env:setup",
    "test:e2e:teardown": "cd e2e && npm run env:teardown",
    "spec": "vitest --run",
    "spec:watch": "vitest --watch",
    "spec:coverage": "vitest --run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf .next out coverage src/lib/api/generated",
    "api:clean": "rimraf src/lib/api/generated",
    "preapi:gen": "npm run api:clean",
    "api:gen": "pnpm exec openapi-ts -f openapi-ts.config.ts",
    "postapi:gen": "npm run format && npm run lint:fix"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@memoriaali/access-control": "workspace:*",
    "@memoriaali/variant-config": "workspace:*",
    "bootstrap": "^5.3.8",
    "cuid": "^3.0.0",
    "lodash.debounce": "^4.0.8",
    "next": "15.5.2",
    "next-intl": "^4.5.6",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-code-input": "^3.10.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.67.0",
    "react-select": "^5.10.2",
    "rxjs": "^7.8.2",
    "sass": "^1.94.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@hey-api/client-next": "0.5.1",
    "@hey-api/openapi-ts": "0.88.0",
    "@memoriaali/prettier-config": "workspace:*",
    "@memoriaali/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/react-select": "^5.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "^19.1.0-rc.1-rc-af1b7da-20250421",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.4.7",
    "jsdom": "^27.2.0",
    "rimraf": "^6.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
