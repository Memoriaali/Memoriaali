# =============================================================================
# Memoriaali V2 Environment Configuration
# =============================================================================
# This file contains example environment variables for local development.
# Copy this file to .env and update the values as needed.

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Node.js environment (development, test, production)
NODE_ENV=development

# Backend server port
PORT=3001

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MySQL database connection string for development
# Matches the docker-compose.yml MySQL service configuration
DATABASE_URL=mysql://memoriaali:memoriaali_pass@localhost:3306/memoriaali

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# JWT signing secret (minimum 32 characters required)
# Generate a secure random string for production
JWT_SECRET=dev-secret-key-change-this-in-production-min-32-chars

# JWT token expiration time (optional, defaults to 24h)
JWT_EXPIRES_IN=24h

# Previous JWT secret for key rotation (optional)
# JWT_SECRET_PREVIOUS=previous-secret-key-for-rotation

# =============================================================================
# FIELD ENCRYPTION
# =============================================================================

# 256-bit encryption key for sensitive field encryption (64 hex characters)
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# =============================================================================
# SERVICE INTEGRATION
# =============================================================================

# SIP service URL for E-ARK package generation
SIP_SERVICE_URL=http://localhost:8080

# =============================================================================
# FRONTEND INTEGRATION
# =============================================================================

# Frontend application URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Backend API URL (used by frontend applications)
REACT_APP_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# API SECURITY
# =============================================================================

# Comma-separated list of valid API keys for service authentication
# Generate secure random strings for each service
API_KEYS=dev-api-key-1,dev-api-key-2

# =============================================================================
# LOGGING
# =============================================================================

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# END-TO-END TESTING (E2E)
# =============================================================================

# E2E testing URLs (used by Playwright and Vitest)
BACKEND_URL=http://localhost:8001
FRONTEND_URL_E2E=http://localhost:8002

# E2E database connection (isolated from development)
DATABASE_URL_E2E=mysql://memoriaali_backend_e2e_user:backend_e2e_user_password_123@localhost:33060/memoriaali_backend_e2e

# =============================================================================
# DOCKER DEVELOPMENT
# =============================================================================

# React development server polling (for Docker file watching)
CHOKIDAR_USEPOLLING=true

# Spring Boot profile for SIP service
SPRING_PROFILES_ACTIVE=development

# The target folder, where the generated archive files fill be stored. YKSA
# will listen the folder and fetch the archives to the permanent archiving 
# system 
SIP_OUTPUT_PATH=/sip-packages

# =============================================================================
# FILE STORAGE
# =============================================================================

# File upload directory
UPLOAD_DIR=./storage

# Maximum file size in bytes (10MB = 10485760 bytes)
MAX_FILE_SIZE=10485760

# The variant of the system. The variant will affect on the 
# localization, features and organization info in use with the system.
MEMORIAALI_VARIANT=default