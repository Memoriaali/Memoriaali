{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    // Node.js specific target and libraries
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    // Node.js environment
    "types": ["node"],
    "allowJs": false,
    // Output for Node.js
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // Node.js specific settings
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    // Bundler compatibility for modern Node.js
    "moduleDetection": "force",
    // Path mapping for monorepo packages
    "baseUrl": ".",
    "paths": {
      "@memoriaali/database": ["../../packages/database/dist"],
      "@memoriaali/database/*": ["../../packages/database/dist/*"],
      "@memoriaali/database/generated/client": ["../../packages/database/generated/client"],
      "@memoriaali/api-types": ["../../packages/api-types/dist"],
      "@memoriaali/api-types/*": ["../../packages/api-types/dist/*"],
      "@memoriaali/shared": ["../../packages/shared/dist"],
      "@memoriaali/shared/*": ["../../packages/shared/dist/*"],
      "@memoriaali/access-control": ["../../packages/access-control/dist"],
      "@memoriaali/access-control/*": ["../../packages/access-control/dist/*"],
      "@memoriaali/file-processing": ["../../packages/file-processing/dist"],
      "@memoriaali/file-processing/*": ["../../packages/file-processing/dist/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts", "**/*.spec.ts"],
  "ts-node": {
    "esm": true,
    "files": true,
    "experimentalSpecifierResolution": "node"
  }
}
