  "version": "1.0.0",
  "description": "Shared ESLint configuration for Memoriaali v2.0 monorepo",
  "type": "module",
  "main": "eslint.config.js",
  "exports": {
    ".": "./eslint.config.js",
    "./base": "./configs/base.js",
    "./base/dev": "./configs/base.dev.js",
    "./base/quality": "./configs/base.quality.js",
    "./node/dev": "./configs/node.dev.js",
    "./node/quality": "./configs/node.quality.js",
    "./react/dev": "./configs/react.dev.js",
    "./react/quality": "./configs/react.quality.js"
  },
  "files": [
    "eslint.config.js",
    "configs/"
