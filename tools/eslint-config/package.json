  "devDependencies": {
    "eslint": "^9.33.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "echo 'ESLint config - validated through dependent packages'",
    "test:watch": "echo 'ESLint config - no watch mode needed'",
    "test:coverage": "echo 'ESLint config - no coverage for config files'"
