    "config",
    "memoriaali",
    "typescript",
    "nodejs",
    "react"
  ],
  "dependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.33.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
