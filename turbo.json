{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["dist/**", ".next/**", "target/**", "build/**"],
      "env": ["NODE_ENV"]
    },
    "prebuild": {
      "dependsOn": ["^prebuild"],
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "outputs": ["generated/**", "../api-types/src/generated/**"],
      "inputs": ["schema.prisma", "scripts/fix-generated-imports.js"]
    },
    "db:push": {
      "dependsOn": ["db:generate"],
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:migrate": {
      "dependsOn": ["db:generate"],
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:seed": {
      "dependsOn": ["db:generate", "build"],
      "cache": false,
      "env": ["DATABASE_URL", "NODE_ENV"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**", "test-results.json"],
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV"]
    },
    "test:integration": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:integration:conditional": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:e2e": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_API_URL"]
    },
    "test:e2e:conditional": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_API_URL"]
    },
    "test:e2e:ui": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "NEXT_PUBLIC_API_URL"]
    },
    "lint:dev": {
      "outputs": [],
      "cache": false
    },
    "lint:quality": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "lint": {
      "dependsOn": ["lint:quality"],
      "outputs": []
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "format:check": {
      "outputs": [],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "DATABASE_URL", "NEXT_PUBLIC_API_URL", "JWT_SECRET", "PORT"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "DATABASE_URL", "NEXT_PUBLIC_API_URL", "JWT_SECRET", "PORT"]
    },
    "clean": {
      "cache": false
    },
    "spec": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV"]
    },
    "spec:watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV"]
    },
    "spec:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV"]
    }
  },
  "globalEnv": [
    "CI",
    "TZ"
  ],
  "globalDependencies": [
    ".env",
    ".env.local",
    "tsconfig.json"
  ]
}
