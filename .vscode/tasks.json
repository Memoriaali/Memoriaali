{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check Frontend Server",
      "type": "shell",
      "command": "curl",
      "args": [
        "-f",
        "-s",
        "http://localhost:3000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Checks if Frontend server is running on port 3000"
    },
    {
      "label": "Check Database Connection",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "database",
        "db:generate"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Ensures Prisma client is generated and database is accessible"
    },
    {
      "label": "Start Frontend Server",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "frontend",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": false,
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*ready.*"
          }
        }
      ],
      "detail": "Starts the Next.js frontend development server"
    },
    {
      "label": "Start Backend Server",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "backend",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": false,
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*listening.*|.*started.*"
          }
        }
      ],
      "detail": "Starts the TypeScript backend development server"
    },
    {
      "label": "Start Database",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "up",
        "-d",
        "mysql"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Starts the MySQL database container"
    },
    {
      "label": "Setup Development Environment",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Start Database",
        "Check Database Connection",
        "Start Backend Server",
        "Start Frontend Server"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "detail": "Sets up complete development environment with database, backend, and frontend"
    },
    {
      "label": "Run Backend Tests",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "backend",
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": "$tsc",
      "detail": "Runs backend unit and integration tests"
    },
    {
      "label": "Run Frontend Tests",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "frontend",
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": "$tsc",
      "detail": "Runs frontend component and integration tests"
    },
    {
      "label": "Build All Packages",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": "$tsc",
      "detail": "Builds all packages in the monorepo"
    },
    {
      "label": "Lint All Code",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "lint"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": "$eslint-stylish",
      "detail": "Runs ESLint across all packages"
    }
  ]
} 